{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://psconnmon.local/schemas/psconnmon-config.schema.json",
  "title": "PSConnMon Config v1",
  "type": "object",
  "required": ["schemaVersion", "agent", "publish", "tests", "auth", "targets", "internetTargets", "extensions"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "agent": {
      "type": "object",
      "required": ["agentId", "siteId", "spoolDirectory", "batchSize", "publishIntervalSeconds", "configPollIntervalSeconds", "cycleIntervalSeconds", "maxRuntimeMinutes", "cleanupAfterDays"]
    },
    "publish": {
      "type": "object",
      "required": ["mode", "format", "csvMirror", "azure"]
    },
    "tests": {
      "type": "object",
      "required": ["enabled", "pingTimeoutMs", "pingPacketSize", "shareAccessTimeoutSeconds", "tracerouteTimeoutSeconds", "tracerouteProbeTimeoutSeconds", "internetQualitySampleCount"]
    },
    "auth": {
      "type": "object",
      "required": ["linuxSmbMode", "secretReference"],
      "properties": {
        "linuxSmbMode": {
          "type": "string"
        },
        "secretReference": {
          "type": "string"
        },
        "linuxProfiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "mode", "secretReference"],
            "properties": {
              "id": {
                "type": "string"
              },
              "mode": {
                "type": "string",
                "enum": ["currentContext", "kerberosKeytab", "usernamePassword"]
              },
              "secretReference": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "fqdn", "address", "roles", "tags", "dnsServers", "shares", "tests"],
        "properties": {
          "id": {
            "type": "string"
          },
          "fqdn": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dnsServers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "shares": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "path"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "linuxProfileId": {
                  "type": "string"
                }
              }
            }
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "linuxProfileId": {
            "type": "string"
          }
        }
      }
    },
    "internetTargets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "address"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "entryPoint": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
