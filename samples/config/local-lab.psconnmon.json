{
  "schemaVersion": "1.0",
  "agent": {
    "agentId": "example-lab-monitor",
    "siteId": "example-lab",
    "spoolDirectory": "data/spool",
    "batchSize": 250,
    "publishIntervalSeconds": 30,
    "configPollIntervalSeconds": 60,
    "cycleIntervalSeconds": 30,
    "maxRuntimeMinutes": 0,
    "cleanupAfterDays": 7
  },
  "publish": {
    "mode": "local",
    "format": "jsonl",
    "csvMirror": true,
    "azure": {
      "enabled": false,
      "accountName": "psconnmonstorage",
      "containerName": "telemetry",
      "blobPrefix": "events",
      "configBlobPath": "configs/example-lab-monitor.yaml",
      "authMode": "managedIdentity",
      "sasToken": ""
    }
  },
  "tests": {
    "enabled": [
      "ping",
      "dns",
      "internetQuality",
      "traceroute"
    ],
    "pingTimeoutMs": 3000,
    "pingPacketSize": 56,
    "shareAccessTimeoutSeconds": 10,
    "tracerouteTimeoutSeconds": 60,
    "tracerouteProbeTimeoutSeconds": 3,
    "internetQualitySampleCount": 4
  },
  "auth": {
    "linuxSmbMode": "currentContext",
    "secretReference": "",
    "linuxProfiles": []
  },
  "targets": [
    {
      "id": "hq-edge",
      "fqdn": "hq-edge.example.net",
      "address": "198.51.100.10",
      "roles": [
        "edge"
      ],
      "tags": [
        "example",
        "demo"
      ],
      "dnsServers": [
        "1.1.1.1"
      ],
      "shares": [],
      "tests": [
        "ping",
        "dns",
        "internetQuality",
        "traceroute"
      ],
      "externalTraceTarget": "8.8.8.8"
    }
  ],
  "extensions": []
}
